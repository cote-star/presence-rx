# Copy to .env and fill with local hackathon credentials.
# Never commit .env or real keys.

# Google DeepMind / Gemini
GEMINI_API_KEY=
GEMINI_MODEL=

# Tavily
TAVILY_API_KEY=

# Lovable
LOVABLE_PROJECT_ID=

# Peec AI MCP - OAuth 2.0, no API key needed (browser consent on first use)
# Server: https://api.peec.ai/mcp
# Setup: claude mcp add peec-ai --transport http https://api.peec.ai/mcp
PEEC_PROJECT_ID=

# Optional eligible partners / side paths.
ENTIRE_API_KEY=
PIONEER_API_KEY=

# App/runtime
APP_ENV=development
LOG_LEVEL=info
